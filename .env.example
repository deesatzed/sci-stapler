# agentmedq configuration

# Server
AGENTMEDQ_HOST=127.0.0.1
AGENTMEDQ_PORT=8042

# Cache TTLs (seconds)
AGENTMEDQ_SEARCH_CACHE_TTL=86400
AGENTMEDQ_PAPER_CACHE_TTL=2592000

# Optional: NCBI API key for higher rate limits (10 req/s vs 3 req/s)
# Register at https://www.ncbi.nlm.nih.gov/account/
# NCBI_API_KEY=

# Optional: OpenAlex polite pool email (higher rate limits)
# OPENALEX_EMAIL=

# Cache database path
AGENTMEDQ_DB_PATH=./agentmedq_cache.db
